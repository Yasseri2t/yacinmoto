APP_NAME=ScootZone
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-app.onrender.com

LOG_CHANNEL=stderr
LOG_LEVEL=error

DB_CONNECTION=sqlite

SESSION_DRIVER=file
SESSION_LIFETIME=120

CACHE_STORE=file
QUEUE_CONNECTION=sync
FILESYSTEM_DISK=public

ADMIN_PASSWORD=change_this_password

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@scootzone.dz"
MAIL_FROM_NAME="${APP_NAME}"
